{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@matka/types": ["packages/backend/src/types/index.ts"],
      "@matka/backend/*": ["packages/backend/src/*"],
      "@matka/frontend/*": ["packages/frontend/src/*"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "packages/*/dist",
    "packages/*/node_modules"
  ]
}
